@article{martinez-delgadoDISCOVERYGIANTStelLAR2009,
  title = {Discovery of a {{Giant Stellar Tidal Stream Around}} the {{Disk Galaxy NGC}} 4013},
  author = {Martínez-Delgado, David and Pohlen, Michael and Gabany, R. Jay and Majewski, Steven R. and Peñarrubia, Jorge and Palma, Chris},
  date = {2009-02},
  journaltitle = {The Astrophysical Journal},
  shortjournal = {ApJ},
  volume = {692},
  number = {2},
  pages = {955},
  publisher = {The American Astronomical Society},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/692/2/955},
  url = {https://doi.org/10.1088/0004-637X/692/2/955},
  urldate = {2026-06-03},
  abstract = {We report the discovery of a giant, looplike stellar structure around the edge-on spiral galaxy NGC 4013. This arcing feature extends 6′ (∼26 kpc in projected distance) northeast from the center and 3′ (≃12 kpc) from the disk plane; likely related features are also apparent on the southwest side of the disk, extending to 4′ (∼17 kpc). The detection of this low surface brightness (μR = 27.0+0.3−0.2 mag arcsec−2) structure is independently confirmed in three separate datasets from three different telescopes. Although its true three-dimensional geometry is unknown, the sky-projected morphology of this structure displays a match with the theoretical predictions for the edge-on, projected view of a stellar tidal stream of a dwarf satellite moving in a low inclined (≃25°), nearly circular orbit. Using the recent model of the Monoceros tidal stream in the Milky Way by Peñarrubia and colleagues as a template, we find that the progenitor system may have been a galaxy with an initial mass 6 × 108 M☉, whose current position and final fate are unknown. According to this simulation, the tidal stream may be approximately ∼2.8 Gyr of age. Our results demonstrate that NGC 4013, previously considered a prototypical isolated disk galaxy in spite of having one of the most prominent H i warps detected thus far, may have in fact suffered a recent minor merger. This discovery highlights that undisturbed disks at high surface brightness levels in the optical but warped in H i maps may in fact reveal complex signatures of recent accretion events in deep photometric surveys.},
  langid = {english},
  file = {/home/daniel/Zotero/storage/VBRIL9DX/Martínez-Delgado et al. - 2009 - Discovery of a Giant Stellar Tidal Stream Around the Disk Galaxy NGC 4013.pdf}
}

@article{mcconnachieRemnantsGalaxyFormation2009,
  title = {The Remnants of Galaxy Formation from a Panoramic Survey of the Region around {{M31}}},
  author = {McConnachie, Alan W. and Irwin, Michael J. and Ibata, Rodrigo A. and Dubinski, John and Widrow, Lawrence M. and Martin, Nicolas F. and Côté, Patrick and Dotter, Aaron L. and Navarro, Julio F. and Ferguson, Annette M. N. and Puzia, Thomas H. and Lewis, Geraint F. and Babul, Arif and Barmby, Pauline and Bienaymé, Olivier and Chapman, Scott C. and Cockcroft, Robert and Collins, Michelle L. M. and Fardal, Mark A. and Harris, William E. and Huxor, Avon and Mackey, A. Dougal and Peñarrubia, Jorge and Rich, R. Michael and Richer, Harvey B. and Siebert, Arnaud and Tanvir, Nial and Valls-Gabaud, David and Venn, Kimberly A.},
  date = {2009-09},
  journaltitle = {Nature},
  volume = {461},
  number = {7260},
  pages = {66--69},
  publisher = {Nature Publishing Group},
  issn = {1476-4687},
  doi = {10.1038/nature08327},
  url = {https://www.nature.com/articles/nature08327},
  urldate = {2026-06-03},
  abstract = {A panoramic survey of the region around our nearest galactic neighbour, the well known Andromeda galaxy M31, has detected stars and coherent structures that are almost certainly remnants of dwarf galaxies destroyed by M31's tidal field. The brightest companion, the Triangulum galaxy (M33), is surrounded by a previously unknown prominent stellar structure that provides evidence for a recent encounter with M31. This new view of galactic structures is consistent with hierarchical cosmological models in which galaxies grow in mass by the accretion of smaller ones.},
  langid = {english},
  keywords = {Humanities and Social Sciences,multidisciplinary,Science},
  file = {/home/daniel/Zotero/storage/HJI9W647/McConnachie et al. - 2009 - The remnants of galaxy formation from a panoramic survey of the region around M31.pdf}
}

@incollection{newbergIntroductionTidalStreams2016,
  title = {Introduction to {{Tidal Streams}}},
  booktitle = {Tidal {{Streams}} in the {{Local Group}} and {{Beyond}}: {{Observations}} and {{Implications}}},
  author = {Newberg, Heidi Jo},
  editor = {Newberg, Heidi Jo and Carlin, Jeffrey L.},
  date = {2016},
  pages = {1--29},
  publisher = {Springer International Publishing},
  location = {Cham},
  doi = {10.1007/978-3-319-19336-6_1},
  url = {https://doi.org/10.1007/978-3-319-19336-6_1},
  urldate = {2026-06-03},
  abstract = {Dwarf galaxies that come too close to larger galaxies suffer tidal disruption; the differential gravitational force between one side of the galaxy and the other serves to rip the stars from the dwarf galaxy so that they instead orbit the larger galaxy. This process produces “tidal streams” of stars, which can be found in the stellar halo of the Milky Way, as well as in halos of other galaxies. This chapter provides a general introduction to tidal streams, including the mechanism through which the streams are created, the history of how they were discovered, and the observational techniques by which they can be detected. In addition, their use in unraveling galaxy formation histories and the distribution of dark matter in galaxies is discussed, as is the interaction between these dwarf galaxy satellites and the disk of the larger galaxy.},
  isbn = {978-3-319-19336-6},
  langid = {english},
  keywords = {Dark Matter,Dwarf Galaxy,Galactic Disk,Globular Cluster,Stellar Population},
  file = {/home/daniel/Zotero/storage/DCV55NIU/Newberg - 2016 - Introduction to Tidal Streams.pdf}
}

@article{pengDETAILEDDECOMPOSITIONGALAXY2010,
  title = {Detailed {{Decomposition}} of {{Galaxy Images}}. {{II}}. {{Beyond Axisymmetric Models}}},
  author = {Peng, Chien Y. and Ho, Luis C. and Impey, Chris D. and Rix, Hans-Walter},
  date = {2010-04},
  journaltitle = {The Astronomical Journal},
  shortjournal = {AJ},
  volume = {139},
  number = {6},
  pages = {2097},
  publisher = {The American Astronomical Society},
  issn = {1538-3881},
  doi = {10.1088/0004-6256/139/6/2097},
  url = {https://doi.org/10.1088/0004-6256/139/6/2097},
  urldate = {2026-05-31},
  abstract = {We present a two-dimensional (2D) fitting algorithm (Galfit, ver. 3) with new capabilities to study the structural components of galaxies and other astronomical objects in digital images. Our technique improves on previous 2D fitting algorithms by allowing for irregular, curved, logarithmic and power-law spirals, ring, and truncated shapes in otherwise traditional parametric functions like the Sérsic, Moffat, King, Ferrer, etc., profiles. One can mix and match these new shape features freely, with or without constraints, and apply them to an arbitrary number of model components of numerous profile types, so as to produce realistic-looking galaxy model images. Yet, despite the potential for extreme complexity, the meaning of the key parameters like the Sérsic index, effective radius, or luminosity remains intuitive and essentially unchanged. The new features have an interesting potential for use to quantify the degree of asymmetry of galaxies, to quantify low surface brightness tidal features beneath and beyond luminous galaxies, to allow more realistic decompositions of galaxy subcomponents in the presence of strong rings and spiral arms, and to enable ways to gauge the uncertainties when decomposing galaxy subcomponents. We illustrate these new features by way of several case studies that display various levels of complexity.},
  langid = {english},
  file = {/home/daniel/Zotero/storage/ALAIVYXN/Peng et al. - 2010 - Detailed Decomposition of Galaxy Images. II. Beyond Axisymmetric Models.pdf}
}

