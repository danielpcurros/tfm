  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/161467},
  url = {https://ui.adsabs.harvard.edu/abs/1983ApJ...274..534M},
  urldate = {2026-06-03},
  abstract = {We present a catalog of 137 elliptical galaxies south of -17 deg declination which exhibit shell or ripple features at large distances from the galaxy or in the outer envelope. Some of these galaxies show similar features in the inner envelope when suitable high resolution plate material is examined. Very few of the galaxies are associated with radio sources. We discuss the environment of shell galaxies, and the proportion of ellipticals which have these features. It appears that about half of the galaxies with shells are isolated and most of the rest are members of small groups. We discuss several individual examples which appear to be typical of this class of galaxy, and others which probably illustrate an evolutionary sequence.},
  keywords = {Astronomical Catalogs,Astronomical Photography,Astronomy,Elliptical Galaxies,Galactic Evolution,Galactic Structure},
  annotation = {ADS Bibcode: 1983ApJ...274..534M},
